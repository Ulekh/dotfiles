#!/bin/zsh
# Accept "light" or "dark" as the first argument (passed by dark-notify)
# If no argument, detect manually
MODE=$1
if [[ -z "$MODE" ]]; then
    STYLE=$(defaults read -g AppleInterfaceStyle 2>/dev/null)
    [[ "$STYLE" == "Dark" ]] && MODE="dark" || MODE="light"
fi

if [[ "$MODE" == "dark" ]]; then
    NEW_THEME="mocha.conf"
else
    NEW_THEME="latte.conf"
fi

TARGET_THEME="$HOME/.tmux/themes/$NEW_THEME"
CURRENT_LINK=$(readlink "$HOME/.tmux/themes/current.conf" 2>/dev/null)

if [[ "$CURRENT_LINK" != "$TARGET_THEME" ]]; then
    ln -sf "$TARGET_THEME" "$HOME/.tmux/themes/current.conf"
    if pgrep -x tmux >/dev/null; then
        tmux source-file "$HOME/.tmux/themes/current.conf"
    fi
fi
